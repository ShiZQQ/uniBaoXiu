
.container {
	padding: 20rpx;
}
.card {
	background-color: #fff;
	border-radius: 10rpx;
	box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
	padding: 20rpx;
	margin-bottom: 20rpx;
}
.card-header {
	font-size: 32rpx;
	font-weight: bold;
	margin-bottom: 20rpx;
}
.card-content {
	font-size: 28rpx;
	line-height: 1.5;
	margin-bottom: 20rpx;
}
.card-footer {
	font-size: 24rpx;
	color: #999;
}
.back-btn {
	background-color: #fff;
	border-radius: 10rpx;
	box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
	padding: 10rpx 20rpx;
	font-size: 28rpx;
	color: #333;
	text-align: center;
}

